<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Center everything -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Display -->
        <EditText
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="end"
            android:textSize="28sp"
            android:hint="0"
            android:inputType="none"
            android:background="#FFFFFF"
            android:padding="10dp"/>

        <!-- Buttons -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:rowCount="5"
            android:columnCount="4"
            android:layout_marginTop="10dp">

            <!-- Row 1 -->
            <Button android:text="7" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="8" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="9" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="/" style="@style/btn" android:onClick="onClick"/>

            <!-- Row 2 -->
            <Button android:text="4" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="5" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="6" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="*" style="@style/btn" android:onClick="onClick"/>

            <!-- Row 3 -->
            <Button android:text="1" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="2" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="3" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="-" style="@style/btn" android:onClick="onClick"/>

            <!-- Row 4 -->
            <Button android:text="0" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="C" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="=" style="@style/btn" android:onClick="onClick"/>
            <Button android:text="+" style="@style/btn" android:onClick="onClick"/>

        </GridLayout>

    </LinearLayout>

</FrameLayout>